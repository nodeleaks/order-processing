{
  "name": "order-processing",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "local": "tsx --watch --env-file=.env.local src/server.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run tests/smoke --mode smoke",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.600.0",
    "@aws-sdk/client-sfn": "3.600.0",
    "@aws-sdk/client-sns": "3.600.0",
    "@aws-sdk/client-sqs": "3.600.0",
    "@aws-sdk/lib-dynamodb": "3.600.0",
    "@hono/node-server": "1.12.0",
    "@hono/zod-validator": "0.4.0",
    "aws-lambda": "1.0.7",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "0.8.3",
    "hono": "4.12.8",
    "pg": "8.12.0",
    "uuid": "10.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "@types/node": "22.0.0",
    "@types/pg": "8.11.0",
    "@types/uuid": "10.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "typescript": "5.5.0",
    "vitest": "2.0.0"
  }
}
