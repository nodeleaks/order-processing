{
  "name": "order-processing",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "local": "tsx --watch --env-file=.env.local src/server.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run tests/smoke --mode smoke",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1024.0",
    "@aws-sdk/client-sfn": "3.1024.0",
    "@aws-sdk/client-sns": "3.1024.0",
    "@aws-sdk/client-sqs": "3.1024.0",
    "@aws-sdk/lib-dynamodb": "3.600.0",
    "@hono/node-server": "1.19.12",
    "@hono/zod-validator": "0.7.6",
    "aws-lambda": "1.0.6",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "0.8.3",
    "hono": "4.12.8",
    "pg": "8.12.0",
    "uuid": "10.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.161",
    "@types/node": "25.5.2",
    "@types/pg": "8.11.0",
    "@types/uuid": "10.0.0",
    "@vitest/coverage-v8": "4.1.2",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vite": "8.0.4",
    "vitest": "4.1.2"
  }
}
